        trend: `Emerging pattern in ${data.domain || \"domain\"}`,\n        strength: 0.75,\n        evidence: [\"source_1\", \"source_2\"],\n      },\n    ],\n  };\n}\n\nconst handlers: Record<string, (data: any) => Promise<any>> = {\n  \"/lead_score\": leadScore,\n  \"/offer_generator\": offerGenerator,\n  \"/content_angle_rank\": contentAngleRank,\n  \"/close_message_draft\": closeMessageDraft,\n  \"/trend_signal\": trendSignal,\n};\n\nserve({\n  port: 3100,\n  async fetch(req) {\n    const url = new URL(req.url);\n    const path = url.pathname;\n\n    // CORS\n    if (req.method === \"OPTIONS\") {\n      return new Response(null, {\n        headers: {\n          \"Access-Control-Allow-Origin\": \"*\",\n          \"Access-Control-Allow-Methods\": \"POST, OPTIONS\",\n          \"Access-Control-Allow-Headers\": \"Content-Type, Authorization\",\n        },\n      });\n    }\n\n    // Agent card\n    if (path === \"/a2a/agent.json\" || path === \"/.well-known/agent.json\") {\n      const card = await Bun.file(\"../A2A_AGENT_CARD.json\").text();\n      return new Response(card, {\n        headers: { \"Content-Type\": \"application/json\" },\n      });\n    }\n\n    // OpenAPI spec\n    if (path === \"/a2a/openapi.json\" || path === \"/openapi.json\") {\n      // Would convert YAML to JSON here\n      return new Response(JSON.stringify({ openapi: \"3.1.0\", info: { title: \"Mercury A2A\" } }), {\n        headers: { \"Content-Type\": \"application/json\" },\n      });\n    }\n\n    // Health check\n    if (path === \"/health\") {\n      return new Response(JSON.stringify({ status: \"ok\", agent: \"mercury\" }), {\n        headers: { \"Content-Type\": \"application/json\" },\n      });\n    }\n\n    // Service endpoints\n    const handler = handlers[path];\n    if (handler && req.method === \"POST\") {\n      try {\n        const body = await req.json();\n        const result = await handler(body);\n        \n        // TODO: Check x402 payment here\n        // TODO: Log call for metering\n        \n        return new Response(JSON.stringify(result), {\n          headers: {\n            \"Content-Type\": \"application/json\",\n            \"X-Mercury-Cost\": String(PRICING[path.slice(1) as keyof typeof PRICING] || 0),\n            \"X-Mercury-Agent\": \"mercury-v1\",\n          },\n        });\n      } catch (e) {\n        return new Response(JSON.stringify({ error: \"Invalid request\" }), {\n          status: 400,\n          headers: { \"Content-Type\": \"application/json\" },\n        });\n      }\n    }\n\n    return new Response(JSON.stringify({ error: \"Not found\" }), {\n      status: 404,\n      headers: { \"Content-Type\": \"application/json\" },\n    });\n  },\n});\n\nconsole.log(\"Mercury A2A service running on port 3100\");\n"}}],"api":"anthropic-messages","provider":"anthropic","model":"claude-opus-4-5","usage":{"input":8,"output":1321,"cacheRead":112428,"cacheWrite":116,"totalTokens":113873,"cost":{"input":0.00004,"output":0.033025,"cacheRead":0.056214,"cacheWrite":0.0007250000000000001,"total":0.090004}},"stopReason":"toolUse","timestamp":1772459193632}}
